CREATE TRIGGER employee_update_audit
AFTER UPDATE ON employee
FOR EACH ROW
BEGIN
    INSERT INTO employee_audit(emp_id, old_name, old_salary)
    VALUES (OLD.id, OLD.name, OLD.salary);
END //

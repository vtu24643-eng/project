CREATE TRIGGER update_order_total
AFTER INSERT ON order_items
FOR EACH ROW
BEGIN
    UPDATE orders
    SET total_amount = total_amount +
        (SELECT price FROM dishes WHERE id = NEW.dish_id) * NEW.quantity
    WHERE id = NEW.order_id;
END //

